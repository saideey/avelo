# App
APP_NAME=AVELO
APP_ENV=development
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=avelo
POSTGRES_USER=avelo_user
POSTGRES_PASSWORD=strong_password_here
DATABASE_URL=postgresql+asyncpg://avelo_user:strong_password_here@db:5432/avelo

# JWT
JWT_SECRET_KEY=another-long-random-secret-for-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP (test mode - code is always 1234)
OTP_TEST_MODE=true
OTP_TEST_CODE=1234

# Frontend
VITE_API_URL=http://localhost:8741/api/v1
VITE_WS_URL=ws://localhost:8741/ws
